    <div class="stats-wrapper">

        <div class="stat">
            <h2>140+</h2>
            <p>Countries Represented</p>
        </div>

        <div class="stat">
            <h2>100+</h2>
            <p>Student Members</p>
        </div>

        <div class="stat">
